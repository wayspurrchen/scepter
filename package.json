{
  "name": "scepter",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "scepter": "./scepter"
  },
  "scripts": {
    "build": "cd core && tsup",
    "cli": "tsx core/src/cli/index.ts",
    "typecheck": "tsc",
    "test": "cd core && vitest",
    "test:watch": "cd core && vitest --watch",
    "test:integration": "cd core && vitest run --config vitest.integration.config.ts --reporter=verbose",
    "test:integration:watch": "cd core && vitest --config vitest.integration.config.ts --reporter=verbose"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^1.0.35",
    "@anthropic-ai/sdk": "^0.56.0",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.3",
    "chrono-node": "^2.8.3",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "fs-extra": "^11.3.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.8",
    "minimatch": "^10.0.3",
    "openai": "^5.8.2",
    "prettier": "^3.6.1",
    "uuid": "^11.1.0",
    "vitest": "^3.2.4",
    "zod": "^3.25.70"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.29.0",
    "glob": "^11.0.3",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "tsx": "^4.6.2",
    "typescript": "^5.8.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
