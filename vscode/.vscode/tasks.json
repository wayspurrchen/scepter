{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": "absolute",
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "\\[esbuild\\] watching for changes\\.\\.\\."
        },
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+)$",
          "message": 1
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
